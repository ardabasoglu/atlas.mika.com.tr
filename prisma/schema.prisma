generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Better Auth (user, session, account, verification)
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  role          String?   @default("MEMBER") // SYSTEM_ADMIN | ADMIN | MEMBER | GUEST
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                   String    @id @default(cuid())
  userId               String    @map("user_id")
  accountId            String    @map("account_id")
  providerId           String    @map("provider_id")
  accessToken          String?   @map("access_token")
  refreshToken         String?   @map("refresh_token")
  accessTokenExpiresAt DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                String?
  idToken              String?   @map("id_token")
  password             String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String   @unique
  value     String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("verifications")
}

// ---------------------------------------------------------------------------
// Enums (mirror src/modules/crm/types and src/modules/project/types)
// ---------------------------------------------------------------------------

enum LeadStatus {
  new
  contacted
  qualified
  lost
  converted

  @@map("lead_status")
}

enum DealStage {
  inquiry
  meeting
  offer
  negotiation
  won
  lost

  @@map("deal_stage")
}

enum TimelineEventEntityType {
  lead
  person
  deal

  @@map("timeline_event_entity_type")
}

enum TimelineEventType {
  note
  call
  meeting
  email
  status_change
  deal_created
  deal_stage_changed

  @@map("timeline_event_type")
}

enum ProjectStatus {
  planning
  construction
  completed
  on_hold

  @@map("project_status")
}

enum UnitType {
  apartment
  commercial
  parking
  other

  @@map("unit_type")
}

enum UnitStatus {
  available
  reserved
  sold

  @@map("unit_status")
}

enum LeadSourceType {
  paid_search
  paid_social
  organic
  referral
  direct
  other

  @@map("lead_source_type")
}

enum LeadSourcePlatform {
  google_ads
  meta_ads
  linkedin_ads
  tiktok_ads
  website_form
  phone_call
  other

  @@map("lead_source_platform")
}

// ---------------------------------------------------------------------------
// Lifecycle (referenced by Lead and Deal via lifecycleId)
// ---------------------------------------------------------------------------

model Lifecycle {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @map("sort_order")
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  leads Lead[]
  deals Deal[]

  @@map("lifecycles")
}

// ---------------------------------------------------------------------------
// LeadSource (user-managed lookup for Lead.source)
// ---------------------------------------------------------------------------

model LeadSource {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @map("sort_order")
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  leads Lead[]

  @@map("lead_sources")
}

// ---------------------------------------------------------------------------
// CRM: Lead → Person (1:1 on conversion), Deal, TimelineEvent
// ---------------------------------------------------------------------------

model Lead {
  id          String     @id @default(cuid())
  name        String
  phone       String?
  email       String
  sourceId    String?    @map("source_id")
  status      LeadStatus
  lifecycleId String?    @map("lifecycle_id")
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  archivedAt DateTime? @map("archived_at")

  sourceType     LeadSourceType?     @map("source_type")
  sourcePlatform LeadSourcePlatform? @map("source_platform")

  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")

  gclid  String? @map("gclid")
  fbclid String? @map("fbclid")

  consentMarketing       Boolean? @map("consent_marketing")
  consentMarketingSource String?  @map("consent_marketing_source")

   convertedAt       DateTime? @map("converted_at")
   convertedByUserId String?   @map("converted_by_user_id")

  duplicateOfLeadId String? @map("duplicate_of_lead_id")
  personId         String?  @map("person_id")

  lifecycle    Lifecycle?   @relation(fields: [lifecycleId], references: [id])
  source       LeadSource?  @relation(fields: [sourceId], references: [id])
  person       Person?      @relation("LeadPerson", fields: [personId], references: [id])
  duplicateOf  Lead?        @relation("LeadDuplicates", fields: [duplicateOfLeadId], references: [id])
  duplicates   Lead[]       @relation("LeadDuplicates")
  personAsOrigin Person?    @relation("PersonOriginLead")

  @@index([email])
  @@index([phone])
  @@index([duplicateOfLeadId])
  @@map("leads")
}

model Person {
  id        String   @id @default(cuid())
  leadId    String?  @unique @map("lead_id")
  name      String
  phone     String?
  email     String
  notes     String?
  archivedAt DateTime? @map("archived_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead   Lead?   @relation("PersonOriginLead", fields: [leadId], references: [id])
  leads  Lead[]  @relation("LeadPerson")
  deals  Deal[]
  units  Unit[]

  @@map("people")
}

model Deal {
  id                 String    @id @default(cuid())
  personId           String    @map("person_id")
  unitId             String?   @unique @map("unit_id")
  title              String
  value              Decimal   @db.Decimal(18, 2)
  currency           String?
  stage              DealStage
  lifecycleId        String?   @map("lifecycle_id")
  expectedCloseDate  DateTime? @db.Date @map("expected_close_date")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  person       Person        @relation(fields: [personId], references: [id], onDelete: Restrict)
  lifecycle    Lifecycle?    @relation(fields: [lifecycleId], references: [id])
  unit         Unit?         @relation("DealUnit", fields: [unitId], references: [id])
  paymentPlan  PaymentPlan?

  @@map("deals")
}

model PaymentPlan {
  id                  String   @id @default(cuid())
  dealId              String   @unique @map("deal_id")
  downPaymentAmount   Decimal  @map("down_payment_amount") @db.Decimal(18, 2)
  installmentCount    Int      @map("installment_count")
  installmentAmount   Decimal  @map("installment_amount") @db.Decimal(18, 2)
  balloonAmount       Decimal  @map("balloon_amount") @db.Decimal(18, 2)
  balloonDueMonth     Int?     @map("balloon_due_month") // 0 = at signing; null = end
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("payment_plans")
}

// ---------------------------------------------------------------------------
// Timeline (polymorphic: entityType + entityId; no FKs to keep flexibility)
// ---------------------------------------------------------------------------

model TimelineEvent {
  id          String                   @id @default(cuid())
  entityType  TimelineEventEntityType @map("entity_type")
  entityId    String                   @map("entity_id")
  type        TimelineEventType
  title       String?
  description String?
  metadata    Json?
  createdBy   String?                  @map("created_by")
  createdAt   DateTime                 @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@map("timeline_events")
}

// ---------------------------------------------------------------------------
// Project & Unit (real estate)
// ---------------------------------------------------------------------------

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  address     String?
  status      ProjectStatus
  startDate   DateTime?     @db.Date @map("start_date")
  endDate     DateTime?     @db.Date @map("end_date")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  units Unit[]

  @@map("projects")
}

model Unit {
  id        String     @id @default(cuid())
  projectId String     @map("project_id")
  code      String
  type      UnitType
  sizeSqm   Float      @map("size_sqm")
  price     Decimal?   @db.Decimal(18, 2)
  currency  String?
  status    UnitStatus
  floor     Int?
  personId  String?    @map("person_id")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)
  person  Person? @relation(fields: [personId], references: [id])
  deal    Deal?   @relation("DealUnit")

  @@map("units")
}
